# ============================================
# EXPRESS TASA — Variables de entorno
# Copia como .env y completa los valores
# ============================================

# --- Dominio (mismo patrón que DOMAIN_WP, DOMAIN_N8N en tu stack) ---
DOMAIN_TASA=veshoy.com

# --- Seguridad API ---
API_ADMIN_TOKEN=cambia_este_token_por_uno_seguro
TOKEN_INTERNO=cambia_este_token_interno

# --- Binance (opcional) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- App ---
FLASK_HOST=0.0.0.0
FLASK_PORT=10001
BACKEND_URL=http://express-tasa-api:10001
CORS_ORIGINS=https://veshoy.com

MAX_HISTORY_ENTRIES=5000
SCRAPE_MAX_RETRIES=3
BCV_TIMEOUT_MS=60000
SCRAPER_INTERVAL_SECONDS=3600

PLAYWRIGHT_HEADLESS=true
